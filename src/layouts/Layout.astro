---
import AsideMenu from "@/components/aside/AsideMenu.astro";
import MainHeader from "@/components/main/MainHeader.astro";
import { ViewTransitions } from "astro:transitions";

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Astro description" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/images/me.png" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<ViewTransitions />
	</head>
	<body>
		<div
			id="app"
			class="max-w-[1500px] mx-auto h-screen py-2 md:py-10 gap-4 px-2"
		>
			<!-- aside -->
			<aside
				class="[grid-area:aside] bg-primary rounded-2xl border border-secondary"
			>
				<AsideMenu />
			</aside>

			<!-- main -->
			<main
				class="[grid-area:main] bg-primary rounded-2xl overflow-hidden border border-secondary"
			>
				<MainHeader />
				<div class="px-8 space-y-4">
					<slot />
				</div>
			</main>
		</div>
		<style>
			#app {
				display: grid;
				grid-template-areas: "aside main";
				grid-template-columns: 340px 1fr;
				grid-template-rows: 1fr auto;

				@media (max-width: 768px) {
					grid-template-areas:
						"aside"
						"main";
					grid-template-columns: 1fr;
					grid-template-rows: auto 1fr;
				}
			}
		</style>

		<style is:global>
			html {
				font-family: system-ui, sans-serif;
				background: #13151a;
				background-size: 224px;
				/* color-scheme: dark light; */
			}

			h1,
			h2,
			h3,
			h4,
			h5,
			h6,
			strong,
			a {
				color: #e5e7eb;
			}

			p,
			li {
				color: gray;
			}
		</style>
	</body>
</html>
